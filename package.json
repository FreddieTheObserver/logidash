{
  "name": "logidash",
  "version": "0.1.0",
  "private": true,
  "description": "Backend-first logistics dispatch API platform (NestJS + React).",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n be,fe -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run start:dev -w @logidash/api",
    "dev:frontend": "npm run dev -w @logidash/web",
    "build": "npm run build -w @logidash/api && npm run build -w @logidash/web",
    "lint": "npm run lint -w @logidash/api && npm run lint -w @logidash/web",
    "lint:check": "npm run lint:check -w @logidash/api && npm run lint:check -w @logidash/web",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:migrate": "npm run db:migrate -w @logidash/api",
    "db:seed": "npm run db:seed -w @logidash/api",
    "db:studio": "npm run db:studio -w @logidash/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2"
  }
}
