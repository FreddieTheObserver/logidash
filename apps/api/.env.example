# logidash backend environment
# Copy to .env for local development. Validated at boot (see src/config/env.validation.ts).

NODE_ENV=development
PORT=3000

# CORS origin for the frontend dev server (Vite default port).
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL connection (matches docker-compose.yml).
DATABASE_URL=postgresql://logidash:logidash@localhost:5433/logidash

# Auth (Phase 3+). JWT_SECRET must be at least 32 characters. Generate a strong
# one with `openssl rand -base64 32`. A "change-me" placeholder is rejected at
# boot when NODE_ENV=production.
JWT_SECRET=change-me-dev-only-openssl-rand-base64-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Maps (Phase 5). MAPS_PROVIDER picks the adapter: "ors" (real OpenRouteService,
# requires ORS_API_KEY) or "mock" (deterministic, no network). When unset, "ors"
# is used if ORS_API_KEY is non-empty, otherwise "mock".
#MAPS_PROVIDER=mock

# OpenRouteService. Leave the key blank to fall back to the mock provider.
# Get a free key at https://openrouteservice.org/dev/
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
# Per-request timeout for ORS calls (geocode/directions), in milliseconds.
ORS_TIMEOUT_MS=5000
